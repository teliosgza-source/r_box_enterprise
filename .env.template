# Telios GeoProcessor Environment Configuration
# Copy this file to .env and modify as needed

# Application Settings
TELIOS_APP_NAME=Telios GeoProcessor
TELIOS_VERSION=2.0.0
TELIOS_DEBUG=false
TELIOS_ENV=staging

# Database Configuration - Staging
TELIOS_STAGING_DB_HOST=localhost
TELIOS_STAGING_DB_PORT=5432
TELIOS_STAGING_DB_NAME=telios_geo_staging
TELIOS_STAGING_DB_USER=telios_app
TELIOS_STAGING_DB_PASSWORD=staging_password

# Database Configuration - Production
TELIOS_PROD_DB_HOST=localhost
TELIOS_PROD_DB_PORT=5432
TELIOS_PROD_DB_NAME=telios_geo_production
TELIOS_PROD_DB_USER=telios_app_prod
TELIOS_PROD_DB_PASSWORD=prod_password

# Data Paths (use absolute or relative paths)
TELIOS_DATA_ROOT=~/workspace/dev/data/raw/Telios
TELIOS_PROCESSED_PATH=~/workspace/dev/data/processed/Telios
TELIOS_UPLOAD_PATH=~/workspace/dev/data/uploads

# Country Configuration Path
TELIOS_COUNTRY_CONFIG=./config/country_ids.yaml

# Processing Settings
TELIOS_MAX_WORKERS=4
TELIOS_CHUNK_SIZE=1000
