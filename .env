# Common settings
DATA_ROOT=/home/linson/workspace/dev/data
PROCESSED_PATH=/home/linson/workspace/dev/data/processed/Telios
UPLOAD_PATH=/home/linson/workspace/dev/data/uploads
DEBUG=true
MAX_WORKERS=4
CHUNK_SIZE=1000

# Staging Database - Using telios_user with full permissions
STAGING_DB_HOST=localhost
STAGING_DB_PORT=5432
STAGING_DB_NAME=telios_geo_staging
STAGING_DB_USER=telios_user
STAGING_DB_PASSWORD=telios_password

# Production Database
PROD_DB_HOST=localhost
PROD_DB_PORT=5432
PROD_DB_NAME=telios_geo_production
PROD_DB_USER=telios_user
PROD_DB_PASSWORD=telios_password

# Active environment (staging or production)
ACTIVE_ENV=staging
