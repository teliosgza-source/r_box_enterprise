{
  "name": "telios-geoprocessor",
  "version": "1.0.0",
  "description": "Telios GeoJSON Processing Application - Enterprise Geospatial Data Processing Suite",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build": "electron-builder",
    "dist": "electron-builder --linux --win --mac",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": ["geospatial", "gis", "geojson", "processing", "telios"],
  "author": "Telios",
  "license": "MIT",
  "dependencies": {
    "electron-squirrel-startup": "^1.0.0"
  },
  "devDependencies": {
    "electron": "^27.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.telios.geoprocessor",
    "productName": "Telios GeoProcessor",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "!src/**/*.test.js",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "../../backend",
        "to": "backend",
        "filter": ["**/*.py", "**/requirements.txt"]
      },
      {
        "from": "../../src",
        "to": "src",
        "filter": ["**/*.py"]
      },
      {
        "from": "../../config",
        "to": "config",
        "filter": ["**/*.yaml"]
      }
    ],
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Science",
      "icon": "src/assets/icon.png"
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "src/assets/icon.ico"
    },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.science",
      "icon": "src/assets/icon.icns"
    }
  }
}
